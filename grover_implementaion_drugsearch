SHOTS = 4096

results_per_k = {}
check_iters = [1, 2, 3, 4, 5]

for k in check_iters:
    qc = build_grover_circuit(N_QUBITS, TARGET_STATE, k)
    counts = simulator.run(qc, shots=SHOTS).result().get_counts()
    results_per_k[k] = counts

    target_hits = counts.get(TARGET_STATE, 0)
    probability = target_hits / SHOTS * 100
    marker = "  ← OPTIMAL" if k == OPTIMAL_ITERS else ""
    print(f"  k={k}: P(|{TARGET_STATE}⟩ = target) = {probability:6.2f}% ({target_hits}/{SHOTS} shots){marker}")

optimal_counts = results_per_k[OPTIMAL_ITERS]
