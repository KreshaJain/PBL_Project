def apply_oracle(circuit, n_qubits, target_state):
    for i, bit in enumerate(reversed(target_state)):
        if bit == '0':
            circuit.x(i)

    circuit.h(n_qubits - 1)
    circuit.mcx(list(range(n_qubits - 1)), n_qubits - 1)
    circuit.h(n_qubits - 1)

    for i, bit in enumerate(reversed(target_state)):
        if bit == '0':
            circuit.x(i)

def apply_diffusion(circuit, n_qubits):
    circuit.h(range(n_qubits))
    circuit.x(range(n_qubits))
    circuit.h(n_qubits - 1)
    circuit.mcx(list(range(n_qubits - 1)), n_qubits - 1)
    circuit.h(n_qubits - 1)
    circuit.x(range(n_qubits))
    circuit.h(range(n_qubits))

def build_grover_circuit(n_qubits, target_state, n_iterations):
    qc = QuantumCircuit(n_qubits, n_qubits)
    qc.h(range(n_qubits))
    qc.barrier()

    for iteration in range(n_iterations):
        apply_oracle(qc, n_qubits, target_state)
        qc.barrier()
        apply_diffusion(qc, n_qubits)
        qc.barrier()

    qc.measure(range(n_qubits), range(n_qubits))
    return qc

def classical_linear_search(database, target_state):
    queries = 0
    start = time.perf_counter()
    for state, info in database.items():
        queries += 1
        if state == target_state:
            return queries, time.perf_counter() - start
    return queries, time.perf_counter() - start

