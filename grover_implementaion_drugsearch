def grover_prob_theory(k, N):
    theta = np.arcsin(1 / np.sqrt(N))
    return np.sin((2*k + 1) * theta)**2

def classical_prob_at_k(k, N):
    return min(1.0, k / N)

CLASSICAL_COST_PER_QUERY = 1.0
QUANTUM_COST_PER_ITER = 20.0

def run_with_noise(error_rate, shots=1024):
    nm = NoiseModel()
    nm.add_all_qubit_quantum_error(depolarizing_error(error_rate, 1), ['h','x'])
    nm.add_all_qubit_quantum_error(depolarizing_error(error_rate * 10, 2), ['cx'])
    noisy_sim = AerSimulator(noise_model=nm)
    qc = build_grover_circuit(N_QUBITS, TARGET_STATE, OPTIMAL_ITERS)
    counts = noisy_sim.run(qc, shots=shots).result().get_counts()
    return counts.get(TARGET_STATE, 0) / shots * 100

